# Warframe Market account credentials.
# WARFRAME_MARKET_EMAIL can be replaced with WARFRAME_MARKET_LOGIN if that is clearer for you.
WARFRAME_MARKET_EMAIL=seller@example.com
WARFRAME_MARKET_PASSWORD=change-me

# Telegram bot settings.
# Create a bot with @BotFather and put its token here.
TELEGRAM_BOT_TOKEN=123456789:replace-with-token

# Chat id where notifications should be sent.
# It can be a user id, group id, or channel id where the bot has permission to write.
TELEGRAM_CHAT_ID=123456789

# Polling and persistence.
POLL_INTERVAL_SECONDS=30
STATE_PATH=/app/data/state.sqlite

# Warframe Market request context.
WARFRAME_MARKET_PLATFORM=pc
WARFRAME_MARKET_LANGUAGE=en
WARFRAME_MARKET_CROSSPLAY=true

# Usually you should not change these.
WARFRAME_MARKET_BASE_URL=https://warframe.market
WARFRAME_MARKET_API_BASE_URL=https://api.warframe.market/v1
TELEGRAM_API_BASE_URL=https://api.telegram.org
REQUEST_TIMEOUT_SECONDS=20
